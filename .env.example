# ==========================================
# BACKEND SERVICES CONFIGURATION
# ==========================================
ENVIRONMENT=development
PORT=8000

# Security Settings
# Change SECRET_KEY in production to a secure random string (e.g. openssl rand -hex 32)
SECRET_KEY=super-secret-key-change-in-production-123456789
ACCESS_TOKEN_EXPIRE_MINUTES=11520
REFRESH_TOKEN_EXPIRE_MINUTES=20160

# Database URL
# SQLite default: sqlite:///./healthbot.db
# PostgreSQL template: postgresql://username:password@localhost:5432/database_name
DATABASE_URL=sqlite:///./healthbot.db

# Twilio Credentials
# Leave as ACmock... to run in MOCK mode
TWILIO_ACCOUNT_SID=ACmockaccountsd123456789
TWILIO_AUTH_TOKEN=mockauthtoken123456789
TWILIO_PHONE_NUMBER=+18449013032

# CORS Settings
# Comma-separated allowed origins, e.g. http://localhost:3000,https://my-app.vercel.app
BACKEND_CORS_ORIGINS=*

# External Services
RASA_URL=http://localhost:5005
TRANSLATION_API_URL=http://localhost:8001

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# Vite dev server loads environment variables from .env
# VITE_API_URL takes priority over VITE_API_BASE_URL
VITE_API_URL=http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000
